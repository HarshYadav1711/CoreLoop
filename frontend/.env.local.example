# Copy this file to .env.local and adjust as needed.
# .env.local is read by Next.js for local development and is not committed to git.

# Base URL of the CoreLoop backend (Express server exposing POST /api/run).
# Local backend default port:
NEXT_PUBLIC_API_URL=http://localhost:3001

# In production (Vercel), set this to your Render backend URL, for example:
# NEXT_PUBLIC_API_URL=https://coreloop-backend.onrender.com
